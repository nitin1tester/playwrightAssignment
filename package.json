{
  "name": "@nitin1tester/pwswaglabsuiframework",
  "version": "1.0.1",
  "description": "playwright test framework",
  "main": "dist/index.js",
  "type": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "npx playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:critical": "playwright test --grep @critical",
    "test:no-flaky": "playwright test --grep-invert @flaky",
    "test:dev": "npx playwright test --config=playwright.config.dev.ts",
    "test:qa": "npx playwright test --config=playwright.config.qa.ts",
    "test:stage": "npx playwright test --config=playwright.config.stage.ts",
    "test:prod": "npx playwright test --config=playwright.config.ts",
    "lint": "eslint . --ext .ts,.js --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:report": "eslint . --ext .ts,.js -f html -o eslint-report/index.html || true",
    "lint:report:json": "eslint . --ext .ts,.js -f json -o eslint-report/eslint-results.json || true",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "prepublishOnly": "npm run build",
    "publish:nexus": "npm publish --registry=http://localhost:8081/repository/npm-private/"
  },
  "keywords": [
    "playwright",
    "automation",
    "framwork"
  ],
  "author": "Nitin R",
  "license": "MIT",
  "publishConfig": {
    "registry": "http://localhost:8081/repository/npm-private/"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.8.0",
    "eslint": "^8.57.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "playwright-html-reporter": "^0.1.11",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "wine": "^0.9.13"
  }
}
